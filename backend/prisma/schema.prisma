datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  phone          String
  totalSpends    Float           @default(0.0)
  lastVisitDate  DateTime?
  loyaltyPoints  Float           @default(0.0)
  favoriteCategory String        @default("Coffee")
  discountSeekingBehavior String @default("MID") // LOW, MID, HIGH
  preferredShoppingDay String   @default("Saturday")
  referrerId     String?
  referrer       Customer?       @relation("CustomerReferral", fields: [referrerId], references: [id])
  referred       Customer[]      @relation("CustomerReferral")
  location       String          @default("Chennai, India")
  feedback       String          @default("Excellent products and fast delivery!")
  modeOfPayment  String          @default("UPI")
  preferredCommunication String   @default("WHATSAPP")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orders         Order[]
  communications Communication[]

  @@index([email])
}

model Order {
  id        String   @id @default(uuid())
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount    Float
  itemCount Int      @default(1)
  category  String   // e.g. "Coffee", "Fashion"
  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([customerId, category, amount])
}

model Campaign {
  id              String          @id @default(uuid())
  name            String
  promptText      String?
  messageTemplate String?
  messageTemplateB String?        // Variant B template for A/B testing
  imageUrl        String?         // Optional image URL for Rich Media
  buttons         String?         // Serialized JSON of buttons, e.g. '["Buy Now", "Opt Out"]'
  channel         String          // "WHATSAPP" | "EMAIL" | "SMS" | "RCS"
  status          String          @default("PENDING")
  autoSplit       Boolean         @default(false)
  attributedOrders Int            @default(0)
  attributedRevenue Float         @default(0.0)
  createdAt       DateTime        @default(now())
  communications  Communication[]
  triggers        Trigger[]
}

model Communication {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    String?  // The specific channel used (e.g. WHATSAPP, EMAIL)
  status     String   // "PENDING" | "SENT" | "DELIVERED" | "OPENED" | "CLICKED" | "FAILED"
  statusLevel Int     @default(0) // Logical precedence for optimistic concurrency
  variant    String   @default("A") // A/B testing variant: "A" or "B"
  errorMsg   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  events     CommunicationEvent[]

  @@index([customerId])
  @@index([campaignId])
  @@index([status])
  @@index([campaignId, status]) // Composite index for fast dashboard aggregations
}

model Trigger {
  id         String   @id @default(uuid())
  name       String
  type       String   // e.g. "LAST_VISIT_30_DAYS"
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([campaignId])
}

model Offer {
  id                 String    @id @default(uuid())
  code               String    @unique // e.g., "COMEBACK20", "SPIN_WHEEL_50"
  discountType       String    // "PERCENTAGE", "FLAT"
  value              Float
  minOrderValue      Float     @default(0.0)
  categoryConstraint String?   // Optional targeting category constraint
  maxTotalUsage      Int       @default(1000)
  maxPerCustomer     Int       @default(1)
  currentUsageCount  Int       @default(0)
  createdAt          DateTime  @default(now())
}

model LifecycleJourney {
  id        String   @id @default(uuid())
  name      String   // e.g., "New Customer Welcome Track", "90-Day Churn Prevention"
  isActive  Boolean  @default(true)
  steps     Json     // Array of nodes representing execution milestones, delays, and channel triggers
  createdAt DateTime @default(now())
}

model CommunicationEvent {
  id               String        @id @default(uuid())
  communicationId  String
  communication    Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  status           String
  providerPayload  Json?
  createdAt        DateTime      @default(now())

  @@index([communicationId])
}
