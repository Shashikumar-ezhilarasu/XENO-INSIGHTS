# Database configuration (Supabase PostgreSQL - Session Pooler recommended for Prisma)
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?schema=public"

# Gemini API configuration
GEMINI_API_KEY="your_gemini_api_key_here"

# Server Port
PORT=3000

# Backend URL for async mock webhook delivery simulation (set to your deployed Vercel backend URL in production)
BACKEND_URL="https://xeno-insights-for-business.vercel.app"
