{
  "name": "ai-crm-backend",
  "version": "1.0.0",
  "description": "AI-Native Mini Marketing CRM Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "prisma generate && prisma generate --schema=prisma/schema-tenant.prisma && tsc",
    "start": "prisma db push && prisma db push --schema=prisma/schema-tenant.prisma && npm run build && node dist/app.js",
    "tenant:generate": "prisma generate --schema=prisma/schema-tenant.prisma",
    "tenant:push": "prisma db push --schema=prisma/schema-tenant.prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest --runInBand --detectOpenHandles --testTimeout=30000"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.12.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "papaparse": "^5.5.3",
    "prisma": "^5.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
